# ── 密钥 / 环境（绝不提交）────────────────────────────────
.env
.env.*
!.env.example

# ── 公司内部后端（不可开源；本地保留运行，公开 repo 不带）──
# 均依赖内部接口（aigc-channel.aiddit.com / crawler.aiddit.com），公开环境不可用。
# _backends.py 容错加载，缺失自动跳过；公开 repo 只保留可用的 MediaCrawler 7 平台。
platforms/aigc_channel.py
platforms/youtube.py
platforms/x.py

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.Python

# ── 管线运行输出（每次 run 生成，不入库）──────────────────
runs/*
!runs/.gitkeep

# ── 视频转写缓存（下载的视频/音频，体积大）────────────────
.cache/

# ── 编辑器 / 系统 ────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
