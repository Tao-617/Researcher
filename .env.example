# researcher 需要的环境变量（复制为项目根 .env，填入真实值）。
# 评估/排序用 LLM —— 三选一即可，providers.py 按 eval_model 选后端：
GEMINI_API_KEY=            # Google AI Studio（当前默认；OpenAI 兼容端点）
OPEN_ROUTER_API_KEY=       # OpenRouter（可选；切 eval_model=or-flash-lite/sonnet 时用）
QWEN_API_KEY=              # 阿里云 DashScope（可选；eval_model=qwen 时用）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 搜索后端：MediaCrawler（开源，公开版默认）──────────────
# 需在别处 clone 并 `uv sync` 安装 https://github.com/NanmiCoder/MediaCrawler
MEDIACRAWLER_HOME=            # MediaCrawler 仓库根目录（缺省取本仓库同级 ../MediaCrawler）
MEDIACRAWLER_GET_COMMENT=0    # 是否同时抓一级评论（1/0，开了更慢）
MEDIACRAWLER_HEADLESS=0       # 无头模式（1/0；首次每平台需登录，必须 0 可见浏览器扫码）
MEDIACRAWLER_LOGIN_TYPE=qrcode  # qrcode / phone / cookie
MEDIACRAWLER_TIMEOUT=        # 单次搜索子进程超时秒数；留空=按关键词数自动放大（封顶1800s）

# 仅内部使用：=1 时额外加载内部后端（aigc/youtube/x，依赖公司内网接口）。公开环境留空。
RESEARCHER_ENABLE_INTERNAL=

# 可选增强（当前原型未启用）：DEEPGRAM_KEY 用于视频转写。
